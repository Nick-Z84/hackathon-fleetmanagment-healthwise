@model VehicleBookingSystem.Web.Models.CompleteBookingViewModel
@{
    ViewData["Title"] = "Complete Booking";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="mb-4"><i class="bi bi-check-circle me-2"></i>Complete Booking</h2>
        <div class="card mb-3">
            <ul class="list-group list-group-flush">
                <li class="list-group-item d-flex justify-content-between"><span>Vehicle</span><strong>@Model.VehicleDisplay</strong></li>
                <li class="list-group-item d-flex justify-content-between"><span>Booked By</span><strong>@Model.BookedBy</strong></li>
                <li class="list-group-item d-flex justify-content-between"><span>Purpose</span><span>@Model.Purpose</span></li>
                <li class="list-group-item d-flex justify-content-between"><span>Odometer at Start</span><span>@Model.OdometerStart.ToString("N0") km</span></li>
            </ul>
        </div>
        <div class="card">
            <div class="card-body">
                <form asp-action="Complete" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label asp-for="OdometerEnd" class="form-label"></label>
                        <input asp-for="OdometerEnd" class="form-control" type="number" min="@Model.OdometerStart" />
                        <span asp-validation-for="OdometerEnd" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label"></label>
                        <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success"><i class="bi bi-check-circle me-1"></i>Complete Trip</button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
