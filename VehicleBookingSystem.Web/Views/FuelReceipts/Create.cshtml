@model VehicleBookingSystem.Web.Models.AddFuelReceiptViewModel
@{
    ViewData["Title"] = "Add Fuel Receipt";
    bool hasVehicle = Model.VehicleId > 0 && !string.IsNullOrEmpty(Model.QrCodeUrl);
}

<div class="row justify-content-center">
    @* ?? QR Code panel (shown only when a vehicle is pre-selected) ?? *@
    @if (hasVehicle)
    {
        <div class="col-md-3 mb-4 mb-md-0 d-flex flex-column align-items-center">
            <div class="card text-center shadow-sm h-100" style="min-width:200px">
                <div class="card-header bg-primary text-white fw-semibold small py-2">
                    <i class="bi bi-qr-code me-1"></i>Scan to Submit Fuel
                </div>
                <div class="card-body d-flex flex-column align-items-center justify-content-center p-3">
                    <div id="qrcode" class="mb-3"></div>
                    <div class="small text-muted text-center" style="word-break:break-all">
                        <strong>@Model.PreSelectedVehicleDisplay</strong>
                    </div>
                    <div class="mt-2 small text-muted">
                        Scan this QR code or print it and place it in the vehicle so drivers can quickly submit fuel receipts.
                    </div>
                </div>
                <div class="card-footer p-2">
                    <button type="button" class="btn btn-sm btn-outline-secondary w-100"
                            onclick="window.print()">
                        <i class="bi bi-printer me-1"></i>Print QR Code
                    </button>
                </div>
            </div>
        </div>
    }

    <div class="@(hasVehicle ? "col-md-7" : "col-md-7")">
        <h2 class="mb-4"><i class="bi bi-fuel-pump me-2"></i>Add Fuel Receipt</h2>
        <div class="card">
            <div class="card-body">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    @* Carry SourceVehicleId through POST so the controller can redirect back *@
                    <input type="hidden" name="SourceVehicleId" value="@Model.SourceVehicleId" />
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="VehicleId" class="form-label"></label>
                            @if (Model.SourceVehicleId > 0)
                            {
                                @* Vehicle locked — arrived from Vehicle Details page *@
                                <input type="hidden" name="VehicleId" value="@Model.VehicleId" />
                                <div class="form-control bg-light">
                                    <i class="bi bi-car-front me-2 text-muted"></i>
                                    <strong>@Model.PreSelectedVehicleDisplay</strong>
                                </div>
                            }
                            else
                            {
                                <select asp-for="VehicleId" asp-items="Model.Vehicles" class="form-select">
                                    <option value="">— Select a vehicle —</option>
                                </select>
                                <span asp-validation-for="VehicleId" class="text-danger small"></span>
                            }
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Date" class="form-label"></label>
                            <input asp-for="Date" class="form-control" type="date" />
                            <span asp-validation-for="Date" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Station" class="form-label"></label>
                            <input asp-for="Station" class="form-control" placeholder="e.g. BP, Shell, Caltex" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Litres" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="Litres" class="form-control" type="number" step="0.01" id="litres" />
                                <span class="input-group-text">L</span>
                            </div>
                            <span asp-validation-for="Litres" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="CostPerLitre" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="CostPerLitre" class="form-control" type="number" step="0.0001" id="cpl" />
                            </div>
                            <span asp-validation-for="CostPerLitre" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="TotalCost" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="TotalCost" class="form-control" type="number" step="0.01" id="total" />
                            </div>
                            <span asp-validation-for="TotalCost" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="OdometerReading" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="OdometerReading" class="form-control" type="number" />
                                <span class="input-group-text">km</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="UploadedBy" class="form-label"></label>
                            <input asp-for="UploadedBy" class="form-control" readonly />
                        </div>
                        <div class="col-12">
                            <label asp-for="ReceiptFile" class="form-label"></label>
                            <input asp-for="ReceiptFile" class="form-control" type="file" accept=".jpg,.jpeg,.png,.pdf" />
                            <div class="form-text">Accepted: JPG, PNG, PDF</div>
                        </div>
                    </div>
                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-upload me-1"></i>Save Receipt</button>
                        @if (Model.SourceVehicleId > 0)
                        {
                            <a asp-controller="Vehicles" asp-action="Details" asp-route-id="@Model.SourceVehicleId"
                               class="btn btn-outline-secondary">Cancel</a>
                        }
                        else
                        {
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    @if (hasVehicle)
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"
                integrity="sha512-CNgIRecGo7nphbeZ04Sc13ka07paqdeTu0WR1IM4kNcpmBAUSHSuhSuak9QQhTnm/OXbk+LuTchp3RxRV8EMg=="
                crossorigin="anonymous" referrerpolicy="no-referrer"></script>
        <script>
            new QRCode(document.getElementById('qrcode'), {
                text:   '@Html.Raw(Model.QrCodeUrl)',
                width:  160,
                height: 160,
                colorDark:  '#000000',
                colorLight: '#ffffff',
                correctLevel: QRCode.CorrectLevel.M
            });
        </script>
    }
    <script>
        // Auto-calculate total when litres or cost-per-litre change
        const litresEl = document.getElementById('litres');
        const cplEl    = document.getElementById('cpl');
        const totalEl  = document.getElementById('total');
        function calcTotal() {
            const l = parseFloat(litresEl.value) || 0;
            const c = parseFloat(cplEl.value) || 0;
            if (l > 0 && c > 0) totalEl.value = (l * c).toFixed(2);
        }
        litresEl.addEventListener('input', calcTotal);
        cplEl.addEventListener('input', calcTotal);
    </script>
}
