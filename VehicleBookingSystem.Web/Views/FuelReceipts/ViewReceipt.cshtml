@model VehicleBookingSystem.Core.Models.FuelReceipt
@{
    ViewData["Title"] = $"Receipt #{Model.Id}";
    Layout = null;   // standalone page for clean print
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Fuel Receipt #@Model.Id</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            background: #e8e8e8;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            min-height: 100vh;
            padding: 30px 10px;
            font-family: 'Courier New', Courier, monospace;
        }
        .receipt-wrap {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 16px;
        }
        /* Paper receipt */
        .receipt {
            width: 320px;
            background: #fffef8;
            border-radius: 2px 2px 0 0;
            box-shadow: 0 4px 24px rgba(0,0,0,.25);
            position: relative;
        }
        /* Torn top edge */
        .receipt::before {
            content: '';
            display: block;
            height: 16px;
            background: repeating-linear-gradient(
                -45deg, #fffef8 0 8px, #e8e8e8 8px 10px
            );
        }
        /* Torn bottom edge */
        .receipt::after {
            content: '';
            display: block;
            height: 16px;
            background: repeating-linear-gradient(
                45deg, #fffef8 0 8px, #e8e8e8 8px 10px
            );
        }
        .receipt-body { padding: 12px 22px 8px; }
        .receipt-header { text-align: center; margin-bottom: 12px; }
        .receipt-header .station {
            font-size: 1.25rem; font-weight: 700; letter-spacing: 2px;
            text-transform: uppercase;
        }
        .receipt-header .sub {
            font-size: 0.72rem; color: #555; margin-top: 2px;
        }
        .divider {
            border: none;
            border-top: 1px dashed #888;
            margin: 8px 0;
        }
        .row {
            display: flex;
            justify-content: space-between;
            font-size: 0.78rem;
            margin: 3px 0;
        }
        .row .label { color: #444; }
        .row .value { font-weight: 600; text-align: right; }
        .total-row {
            display: flex;
            justify-content: space-between;
            font-size: 1.05rem;
            font-weight: 700;
            margin: 6px 0 4px;
        }
        .receipt-footer {
            text-align: center;
            font-size: 0.65rem;
            color: #888;
            margin-top: 10px;
        }
        .barcode {
            text-align: center;
            letter-spacing: -1px;
            font-size: 2rem;
            line-height: 1;
            margin: 10px 0 4px;
            color: #111;
        }
        /* Uploaded image (if any) */
        .uploaded-img { width: 320px; border-radius: 4px; box-shadow: 0 2px 12px rgba(0,0,0,.2); }
        /* Action buttons */
        .actions { display: flex; gap: 10px; justify-content: center; margin-top: 4px; }
        .btn {
            padding: 8px 20px; border: none; border-radius: 4px;
            cursor: pointer; font-size: 0.9rem; text-decoration: none;
        }
        .btn-print { background: #0d6efd; color: #fff; }
        @@media print {
            body { background: #fff; padding: 0; }
            .actions { display: none; }
        }
    </style>
</head>
<body>
    <div class="receipt-wrap">

        @* ?? Paper receipt ?? *@
        <div class="receipt">
            <div class="receipt-body">
                <div class="receipt-header">
                    <div class="station">@(Model.Station?.ToUpperInvariant() ?? "FUEL STATION")</div>
                    <div class="sub">
                        @(Model.Vehicle != null
                            ? $"{Model.Vehicle.Year} {Model.Vehicle.Make} {Model.Vehicle.Model} À {Model.Vehicle.LicensePlate}"
                            : $"Vehicle #{Model.VehicleId}")
                    </div>
                    <div class="sub">@Model.Date.ToString("ddd dd MMMM yyyy")</div>
                </div>
                <hr class="divider" />

                <div class="row">
                    <span class="label">Fuel Type</span>
                    <span class="value">UNLEADED</span>
                </div>
                <div class="row">
                    <span class="label">Litres</span>
                    <span class="value">@Model.Litres.ToString("F2") L</span>
                </div>
                <div class="row">
                    <span class="label">Price / Litre</span>
                    <span class="value">$@Model.CostPerLitre.ToString("F4")</span>
                </div>
                @if (Model.OdometerReading.HasValue)
                {
                    <div class="row">
                        <span class="label">Odometer</span>
                        <span class="value">@Model.OdometerReading.Value.ToString("N0") km</span>
                    </div>
                }
                <hr class="divider" />
                <div class="total-row">
                    <span>TOTAL</span>
                    <span>$@Model.TotalCost.ToString("F2")</span>
                </div>
                <hr class="divider" />

                @* Barcode-style decoration *@
                <div class="barcode" aria-hidden="true">
                    &#x2590;&#x2581;&#x2588;&#x2581;&#x2590;&#x2588;&#x2581;&#x2590;&#x2581;&#x2588;&#x2590;&#x2581;&#x2588;
                </div>
                <div class="receipt-footer">
                    Receipt #@Model.Id &nbsp;À&nbsp; Uploaded by @Model.UploadedBy<br/>
                    @Model.UploadedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                </div>
            </div>
        </div>

        @* ?? Uploaded photo (if any) ?? *@
        @if (Model.ReceiptFilePath != null)
        {
            <img src="/@Model.ReceiptFilePath" class="uploaded-img" alt="Uploaded receipt photo" />
        }

        @* ?? Actions ?? *@
        <div class="actions">
            <button class="btn btn-print" onclick="window.print()">
                <span style="font-style:normal">??</span> Print Receipt
            </button>
        </div>
    </div>
</body>
</html>
